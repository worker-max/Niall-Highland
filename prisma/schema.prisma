// HomeHealthTools.com — Prisma schema
// Postgres on Railway.  No PHI ever stored.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// Branch account — one per branch
// =========================================================================
model Branch {
  id               String    @id @default(cuid())
  clerkOrgId       String    @unique
  name             String
  tier             Tier      @default(MAP)
  stripeCustomerId String?
  stripeSubId      String?
  trialEndsAt      DateTime?
  createdAt        DateTime  @default(now())

  counties         County[]
  clinicians       Clinician[]
  uploadSessions   UploadSession[]
  adcRecords       AdcRecord[]
  territories      Territory[]
  ptoRules         PtoRule[]
  ptoRequests      PtoRequest[]
  coverageSlots    CoverageSlot[]
  schoolCalendars  SchoolCalendar[]
  sensitiveWindows SensitiveWindow[]
}

enum Tier {
  MAP
  OPS
  BRANCH
}

// =========================================================================
// Licensed counties for this branch
// =========================================================================
model County {
  id         String   @id @default(cuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stateFips  String
  countyFips String
  stateAbbr  String
  countyName String
  createdAt  DateTime @default(now())

  @@unique([branchId, stateFips, countyFips])
  @@index([branchId])
}

// =========================================================================
// Clinician roster — identified by discipline + number only
// =========================================================================
model Clinician {
  id         String     @id @default(cuid())
  branchId   String
  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  discipline Discipline
  number     Int
  tenureRank Int
  homeZip    String?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())

  territories   TerritoryAssignment[]
  ptoRequests   PtoRequest[]
  coverageSlots CoverageSlot[]
  surveyTokens  SurveyToken[]

  @@unique([branchId, discipline, number])
  @@index([branchId])
}

enum Discipline {
  RN
  PT
  OT
  HHA
  SLP
  LPN
  MSW
}

// =========================================================================
// CSV upload sessions — admission data
// =========================================================================
model UploadSession {
  id           String     @id @default(cuid())
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  uploadType   UploadType
  fileName     String
  rowCount     Int
  quarterStart String
  quarterEnd   String
  createdAt    DateTime   @default(now())

  records AdmissionRecord[]

  @@index([branchId, createdAt])
}

enum UploadType {
  ADMISSIONS
  ADC
}

// Aggregated admission record — no PHI
model AdmissionRecord {
  id               String        @id @default(cuid())
  uploadSessionId  String
  uploadSession    UploadSession @relation(fields: [uploadSessionId], references: [id], onDelete: Cascade)
  tractFips        String?
  zip              String?
  admissionYear    Int
  admissionQuarter Int
  createdAt        DateTime      @default(now())

  @@index([uploadSessionId])
  @@index([tractFips])
  @@index([zip])
}

// Aggregated ADC record by geography — no PHI
model AdcRecord {
  id          String   @id @default(cuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tractFips   String?
  zip         String?
  censusDate  DateTime
  activeCount Int
  createdAt   DateTime @default(now())

  @@index([branchId, censusDate])
}

// =========================================================================
// Territory builder
// =========================================================================
model Territory {
  id        String        @id @default(cuid())
  branchId  String
  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  label     String
  quarter   String
  mode      TerritoryMode @default(TENURE_PRIORITY)
  createdAt DateTime      @default(now())

  assignments TerritoryAssignment[]

  @@index([branchId])
}

enum TerritoryMode {
  TENURE_PRIORITY
  EQUITY_DISTRIBUTION
}

model TerritoryAssignment {
  id              String           @id @default(cuid())
  territoryId     String
  territory       Territory        @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  clinicianId     String
  clinician       Clinician        @relation(fields: [clinicianId], references: [id], onDelete: Cascade)
  tractFips       String?
  zip             String?
  isAnchor        Boolean          @default(false)
  isNonContiguous Boolean          @default(false)
  desirabilityTag DesirabilityTag?
  createdAt       DateTime         @default(now())

  @@index([territoryId])
  @@index([clinicianId])
}

enum DesirabilityTag {
  PRODUCTIVE
  COMPLEX
  GEOGRAPHIC
  SAFETY_FLAGGED
}

// =========================================================================
// PTO Manager
// =========================================================================
model PtoRule {
  id                        String      @id @default(cuid())
  branchId                  String
  branch                    Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  discipline                Discipline?
  maxSimultaneous           Int         @default(1)
  appliesToSensitiveWindows Boolean     @default(true)
  createdAt                 DateTime    @default(now())

  @@index([branchId])
}

model SensitiveWindow {
  id         String     @id @default(cuid())
  branchId   String
  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  label      String
  startDate  DateTime
  endDate    DateTime
  windowType WindowType
  hardBlock  Boolean    @default(false)
  createdAt  DateTime   @default(now())

  @@index([branchId, startDate, endDate])
}

enum WindowType {
  SCHOOL_BREAK
  HOLIDAY
  HIGH_CENSUS
  CUSTOM
}

model SchoolCalendar {
  id           String   @id @default(cuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  districtName String
  schoolYear   String
  rawData      Json
  createdAt    DateTime @default(now())

  @@index([branchId])
}

model PtoRequest {
  id          String    @id @default(cuid())
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicianId String
  clinician   Clinician @relation(fields: [clinicianId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  status      PtoStatus @default(PENDING)
  flagReason  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([branchId, status])
  @@index([clinicianId])
}

enum PtoStatus {
  PENDING
  APPROVED
  FLAGGED
  DENIED
}

// =========================================================================
// Coverage Scheduler
// =========================================================================
model CoverageSlot {
  id                String       @id @default(cuid())
  branchId          String
  branch            Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  clinicianId       String?
  clinician         Clinician?   @relation(fields: [clinicianId], references: [id])
  slotDate          DateTime
  slotType          CoverageType
  status            SlotStatus   @default(UNASSIGNED)
  lockedAt          DateTime?
  swapRequestedWith String?
  createdAt         DateTime     @default(now())

  @@index([branchId, slotDate])
}

enum CoverageType {
  WEEKEND_DAY
  WEEKNIGHT_ONCALL
  HOLIDAY
}

enum SlotStatus {
  UNASSIGNED
  ASSIGNED
  SWAP_PENDING
  CONFIRMED
}

// =========================================================================
// Survey tokens — signed, unauth'd clinician links for PTO/coverage surveys
// =========================================================================
model SurveyToken {
  id          String          @id @default(cuid())
  token       String          @unique
  clinicianId String
  clinician   Clinician       @relation(fields: [clinicianId], references: [id], onDelete: Cascade)
  purpose     SurveyPurpose
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime        @default(now())

  @@index([token])
}

enum SurveyPurpose {
  PTO_REQUEST
  COVERAGE_SIGNUP
}

// =========================================================================
// Census cache — tract/zip boundary GeoJSON + ACS demographics
// =========================================================================
model CensusBoundaryCache {
  id         String   @id @default(cuid())
  stateFips  String
  countyFips String
  type       String // 'tract' | 'zip'
  geojson    Json
  fetchedAt  DateTime @default(now())

  @@unique([stateFips, countyFips, type])
}

model CensusAcsCache {
  id        String   @id @default(cuid())
  geoId     String // tract FIPS (11) or ZIP (5)
  geoType   String // 'tract' | 'zip'
  data      Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@unique([geoId, geoType])
  @@index([expiresAt])
}
