# Required for demos (P1 / P2 / P3). Routes return 503 without it.
ANTHROPIC_API_KEY=

# Rate limiting. Optional \u2014 limiter no-ops without these (local dev).
# Strongly recommended in production to cap spend.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Contact form (Phase 3). Returns 503 until configured \u2014 form falls back
# to a "email directly" message so users aren't blocked.
RESEND_API_KEY=
CONTACT_TO=hello@niallhighland.com
CONTACT_FROM="Niall Highland site <hello@niallhighland.com>"

# Analytics (Phase 2). Optional; wrapper no-ops without key.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Public booking link surfaced in Nav/Contact. Optional.
NEXT_PUBLIC_CALENDLY_URL=

# Niall's Desk — passcode-gated private workspace at /desk. Without the
# passcode set, /desk renders a "not configured" notice. Choose a long
# random string, share with Niall directly. Submissions email DESK_NOTIFY_EMAIL
# (falls back to CONTACT_TO). Requires RESEND_API_KEY to actually deliver.
NIALL_DESK_PASSCODE=
DESK_NOTIFY_EMAIL=

# P5 Talk Explorer (Phase 5). All three required for the live demo. Without
# them the /talks page still renders (static archive); the chat surface
# shows a "coming soon" panel.
OPENAI_API_KEY=                # text-embedding-3-small for retrieval
DATABASE_URL=                  # Neon Postgres with pgvector (run lib/ai/rag/schema.sql)
INGEST_SECRET=                 # Bearer token guarding /api/admin/ingest-talks

# Press kit landing pages (Phase 7). Vercel Blob for image upload; reuses
# DATABASE_URL above for landing_pages settings table (created lazily).
BLOB_READ_WRITE_TOKEN=         # Vercel Blob token; set automatically when you enable Blob in the project
