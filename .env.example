# Anthropic (Territory Builder Agent)
ANTHROPIC_API_KEY=

# OpenRouteService (Drive Time Isochrones)
# Free tier: 40 req/min, register at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# Signed-token secret for clinician survey links
SURVEY_LINK_SECRET=

# ------------------------------------------------------------------
# Notion — source of truth for specs, prompts, agent configs
# Diagram: "The Notion superpower — edit prompts without redeploying"
# ------------------------------------------------------------------
NOTION_API_KEY=
NOTION_MACHINE_REGISTRY_DB=     # Machine Registry DB (tools/machines catalog)
NOTION_AGENT_CONFIG_DB=         # Agent Config DB (model, temperature, tools per agent)
NOTION_PROMPT_LIBRARY_DB=       # Prompt Library DB (system prompts, runtime-fetched)
NOTION_SPRINT_ROADMAP_DB=       # Sprint + Roadmap DB (roadmap, changelog)
NOTION_DOCS_DB=                 # Optional: public help-center pages
NOTION_WEBHOOK_SECRET=          # Shared secret for Notion → app webhook
NOTION_PROMPT_TTL_SECONDS=60    # Runtime prompt cache TTL (low = near-live edits)

# App
NEXT_PUBLIC_APP_URL=https://homehealthtools.com
